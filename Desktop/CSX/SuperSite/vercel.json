{
  "version": 2,
  "name": "bropro",
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "SAMEORIGIN"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=()"
        },
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=63072000; includeSubDomains; preload"
        },
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://www.gstatic.com https://apis.google.com https://accounts.google.com https://*.firebaseio.com https://*.googleapis.com https://sdk.cashfree.com https://checkout.razorpay.com https://www.googletagmanager.com https://cdn.tailwindcss.com; style-src 'self' 'unsafe-inline' blob: https://fonts.googleapis.com https://accounts.google.com https://cdn.tailwindcss.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: blob: https: http:; connect-src 'self' https://*.googleapis.com https://*.firebaseio.com https://*.cloudfunctions.net wss://*.firebaseio.com https://firestore.googleapis.com https://identitytoolkit.googleapis.com https://securetoken.googleapis.com https://accounts.google.com https://oauth2.googleapis.com https://generativelanguage.googleapis.com https://api.groq.com https://sandbox.cashfree.com https://api.cashfree.com https://*.tenor.com https://*.vercel.app https://cdn.tailwindcss.com; frame-src 'self' https://accounts.google.com https://*.google.com https://supersite-2dcf9.firebaseapp.com https://bropro.in https://www.bropro.in https://sdk.cashfree.com https://api.razorpay.com; media-src 'self' blob:; worker-src 'self' blob:; object-src 'none'; base-uri 'self';"
        }
      ]
    },
    {
      "source": "/sw.js",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        },
        {
          "key": "Pragma",
          "value": "no-cache"
        },
        {
          "key": "Expires",
          "value": "0"
        }
      ]
    },
    {
      "source": "/(.*).html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    },
    {
      "source": "/",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    },
    {
      "source": "/version.js",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    },
    {
      "source": "/manifest.json",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    },
    {
      "source": "/scripts/(.*).js",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/styles/(.*).css",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/subjects/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/newadmin/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    },
    {
      "source": "/news/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    },
    {
      "source": "/.well-known/assetlinks.json",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/json"
        },
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        },
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        }
      ]
    },
    {
      "source": "/__/:path*",
      "headers": [
        {
          "key": "X-Frame-Options",
          "value": "SAMEORIGIN"
        },
        {
          "key": "Content-Security-Policy",
          "value": ""
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/__/:path*",
      "destination": "https://supersite-2dcf9.firebaseapp.com/__/:path*"
    },
    {
      "source": "/newadmin",
      "destination": "/newadmin/index.html"
    },
    {
      "source": "/privacy",
      "destination": "/policies/privacy.html"
    },
    {
      "source": "/privacy/",
      "destination": "/policies/privacy.html"
    },
    {
      "source": "/terms",
      "destination": "/policies/terms.html"
    },
    {
      "source": "/terms/",
      "destination": "/policies/terms.html"
    },
    {
      "source": "/refund",
      "destination": "/policies/refund.html"
    },
    {
      "source": "/refund/",
      "destination": "/policies/refund.html"
    },
    {
      "source": "/cancellation",
      "destination": "/policies/cancellation.html"
    },
    {
      "source": "/cancellation/",
      "destination": "/policies/cancellation.html"
    },
    {
      "source": "/shipping",
      "destination": "/policies/shipping.html"
    },
    {
      "source": "/shipping/",
      "destination": "/policies/shipping.html"
    },
    {
      "source": "/return",
      "destination": "/policies/return.html"
    },
    {
      "source": "/return/",
      "destination": "/policies/return.html"
    },
    {
      "source": "/.well-known/assetlinks.json",
      "destination": "/.well-known/assetlinks.json"
    }
  ]
}
