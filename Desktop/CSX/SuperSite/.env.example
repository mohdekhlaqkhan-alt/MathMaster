# =====================================================
# 🔐 BROPRO ENVIRONMENT VARIABLES
# =====================================================
# 
# ⚠️  SECURITY WARNING ⚠️
# - NEVER commit your actual .env file to Git!
# - NEVER share your API keys publicly!
# - This .env.example is a TEMPLATE only
#
# =====================================================
# HOW TO USE:
# 1. Copy this file and rename to .env
# 2. Replace placeholder values with your real keys
# 3. The .env file is gitignored and won't be committed
# =====================================================

# ===================
# 🔑 ADMIN SETTINGS
# ===================

# Admin Email - The email address with full admin access
# This should match the email you use to login
ADMIN_EMAIL=your_admin_email@example.com

# ===================
# 🤖 AI API KEYS
# ===================

# Google Gemini API Key (Required for BhAI)
# Get FREE key from: https://aistudio.google.com
GEMINI_API_KEY=your_gemini_api_key_here

# Groq API Key (Optional fallback)
# Get FREE key from: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# OpenRouter API Key (Optional - access to 100+ models)
# Get key from: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# ===================
# 💳 PAYMENT GATEWAYS
# ===================

# Cashfree Payment Gateway (Production)
# Get keys from: https://merchant.cashfree.com
CASHFREE_APP_ID=your_cashfree_app_id_here
CASHFREE_SECRET_KEY=your_cashfree_secret_key_here

# PayU Payment Gateway (Optional)
# Get keys from: https://payu.in/business
PAYU_MERCHANT_KEY=your_payu_merchant_key_here
PAYU_MERCHANT_SALT=your_payu_merchant_salt_here

# ===================
# 🔥 FIREBASE (Optional)
# ===================

# Firebase Service Account Key (for server-side operations)
# Get from: Firebase Console > Project Settings > Service Accounts
# Paste the entire JSON as a single line
FIREBASE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"..."}

# =====================================================
# VERCEL DEPLOYMENT INSTRUCTIONS
# =====================================================
# Your API keys are stored SECURELY on Vercel:
#
# 1. Go to https://vercel.com/dashboard
# 2. Select your project (SuperSite)
# 3. Go to Settings → Environment Variables
# 4. Add each variable:
#    - Name: GEMINI_API_KEY
#    - Value: (your actual API key)
#    - Environment: Production, Preview, Development
# 5. Click Save
# 6. Redeploy the project
#
# ✅ Your keys are encrypted and never exposed in code!
# =====================================================
